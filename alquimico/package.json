{
  "name": "alquimico",
  "version": "1.0.0",
  "description": "Zcodex Markdown Notes App",
  "author": "Alquimico",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.alquimico.app",
    "productName": "Alquimico",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "alquimico.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "alquimico.ico",
      "uninstallerIcon": "alquimico.ico"
    }
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  }
}
